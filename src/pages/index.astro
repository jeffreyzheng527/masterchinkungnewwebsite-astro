---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="zh-TW">
<head>
  <meta charset="utf-8" />
  <title>聯合國教科文組織淨空之友社</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Noto+Serif+TC:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&family=Noto+Sans+TC:wght@300;400;500&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --gold-bright: #d4a843;
      --gold-mid: #b8892a;
      --gold-deep: #7a5c1e;
      --ivory: #fefcf5;
      --ivory-warm: #f9f3e1;
      --ink: #1a1208;
      --ink3: #6b5533;
      --font-serif: 'Cormorant Garamond', 'Noto Serif TC', serif;
      --font-body: 'Montserrat', 'Noto Sans TC', sans-serif;
    }
    body {
      cursor: none;
      font-family: var(--font-body);
      background: var(--ivory);
      color: var(--ink);
    }
    ::selection { background: var(--gold-mid); color: #fff; }

    .font-serif-tc { font-family: var(--font-serif); }

    #cursor-ring {
      position: fixed; top: 0; left: 0; z-index: 9999;
      width: 4px; height: 4px; border: 1px solid rgba(212, 168, 67, 0); border-radius: 50%;
      pointer-events: none; transform: translate(-50%, -50%);
      transition: width 0.6s cubic-bezier(0.23,1,0.32,1), height 0.6s cubic-bezier(0.23,1,0.32,1), border-color 0.6s;
    }
    body.show-cursor #cursor-ring { width: 24px; height: 24px; border-color: rgba(212, 168, 67, 0.4); }
    body:has(a:hover, button:hover) #cursor-ring { width: 48px; height: 48px; border-color: var(--gold-bright); background: rgba(212, 168, 67, 0.1); }

    #scroll-progress {
      position: fixed; top: 0; left: 0; z-index: 200; height: 2px; width: 0;
      background: linear-gradient(90deg, transparent, var(--gold-bright), var(--gold-deep));
    }

    .hero-bg-overlay {
      position: absolute; inset: 0; z-index: 2;
      background: linear-gradient(to bottom, rgba(15,10,3,0.7) 0%, rgba(15,10,3,0.25) 30%, rgba(15,10,3,0.35) 55%, rgba(15,10,3,0.9) 100%);
    }
    .hero-buddha-glow {
      position: absolute; inset: 0; z-index: 3; pointer-events: none;
      background: radial-gradient(ellipse 100% 80% at 50% 20%, rgba(212,168,67,0.15) 0%, transparent 50%), radial-gradient(ellipse 60% 40% at 30% 70%, rgba(212,168,67,0.08) 0%, transparent 40%);
      animation: buddhaGlow 8s ease-in-out infinite alternate;
    }
    @keyframes buddhaGlow { 0% { opacity: 0.8; } 100% { opacity: 1; } }

    .nav-scrolled {
      background: rgba(253, 246, 227, 0.98); backdrop-filter: blur(20px); 
      box-shadow: 0 4px 30px rgba(26,18,8,0.08), 0 1px 0 rgba(180,130,30,0.12);
      height: 76px !important;
    }
    .nav-scrolled a.nav-link-item { color: #6b5533 !important; }
    .nav-scrolled a.nav-link-item:hover { color: #7a5c1e !important; }
    
    .nav-link-item { position: relative; padding-bottom: 4px; }
    .nav-link-item::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold-bright), transparent);
      transform: scaleX(0); transform-origin: center; transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .nav-link-item:hover::after { transform: scaleX(1); }

    .architectural-text {
      -webkit-text-stroke: 1px rgba(212, 168, 67, 0.15); color: transparent;
      user-select: none; pointer-events: none;
    }
  </style>
</head>

<body class="antialiased overflow-x-hidden">

  <div id="cursor-ring"></div>
  <div id="scroll-progress"></div>
  
  <audio id="ambient-sound" loop preload="auto">
    <source src="/ambient.mp3" type="audio/mpeg">
  </audio>

  <canvas id="dust-canvas" class="fixed inset-0 z-40 pointer-events-none opacity-0 transition-opacity duration-[4000ms]"></canvas>

  <div id="entrance-veil" class="fixed inset-0 z-[100] bg-[#fefcf5] flex flex-col items-center justify-center transition-all duration-[3000ms]">
    <img src="/photo/logo1.png" alt="Logo" class="h-16 mb-8 opacity-80" />
    <p class="font-serif-tc text-[#b8892a] tracking-[0.2em] text-xl mb-4 animate-pulse">Peace begins with education.</p>
    <p class="text-[#6b5533] tracking-[1.5em] text-[0.75rem] uppercase animate-pulse ml-3">· 淨 · 空 · 之 · 友 · 社 ·</p>
  </div>

  <nav class="fixed top-0 left-0 right-0 z-[1000] flex items-center justify-between px-8 md:px-20 h-[100px] transition-all duration-500" id="main-nav">
    <div class="w-[280px]">
        <img src="/photo/logo1.png" alt="Logo" class="h-[60px] object-contain filter drop-shadow-[0_2px_8px_rgba(0,0,0,0.2)] transition-all duration-500" id="nav-logo" />
    </div>
    <ul class="hidden lg:flex gap-[clamp(16px,2vw,36px)] text-[16px] tracking-[0.08em] font-medium text-white/90 transition-colors duration-500" id="nav-links">
      <li><a href="#home" class="nav-link-item hover:text-[#e8c97a] transition-colors">首頁</a></li>
      <li><a href="#master" class="nav-link-item hover:text-[#e8c97a] transition-colors">友社導師</a></li>
      <li><a href="#about" class="nav-link-item hover:text-[#e8c97a] transition-colors">關於友社</a></li>
      <li><a href="#news" class="nav-link-item hover:text-[#e8c97a] transition-colors">綜合資訊</a></li>
      <li><a href="#education" class="nav-link-item hover:text-[#e8c97a] transition-colors">教學為先</a></li>
      <li><a href="#support" class="nav-link-item hover:text-[#e8c97a] transition-colors">護持友社</a></li>
      <li><a href="#webtv" class="nav-link-item hover:text-[#e8c97a] transition-colors">網路電視</a></li>
      <li><a href="#dharma" class="nav-link-item hover:text-[#e8c97a] transition-colors">數位法寶</a></li>
    </ul>
    <div class="flex gap-1 text-[11px] font-medium tracking-[0.05em] w-[280px] justify-end text-white transition-colors duration-500" id="nav-lang">
      <a href="#" class="border border-white/20 px-[9px] py-[4px] rounded-[2px] hover:bg-[rgba(212,168,67,0.12)] hover:border-[#d4a843] hover:text-[#d4a843] hover:shadow-[0_0_12px_rgba(212,168,67,0.2)] transition-all nav-lang-btn">EN</a>
      <a href="#" class="border border-[#d4a843] text-[#d4a843] bg-[rgba(212,168,67,0.12)] shadow-[0_0_12px_rgba(212,168,67,0.2)] rounded-[2px] px-[9px] py-[4px] nav-lang-btn">中文</a>
      <a href="#" class="border border-white/20 px-[9px] py-[4px] rounded-[2px] hover:bg-[rgba(212,168,67,0.12)] hover:border-[#d4a843] hover:text-[#d4a843] hover:shadow-[0_0_12px_rgba(212,168,67,0.2)] transition-all nav-lang-btn">FR</a>
      <a href="#" class="border border-white/20 px-[9px] py-[4px] rounded-[2px] hover:bg-[rgba(212,168,67,0.12)] hover:border-[#d4a843] hover:text-[#d4a843] hover:shadow-[0_0_12px_rgba(212,168,67,0.2)] transition-all nav-lang-btn">AR</a>
    </div>
  </nav>

  <main>
    <section id="home" class="h-screen min-h-[700px] w-full relative flex items-end overflow-hidden">
      <div class="absolute inset-0 z-1 bg-[#1a1208]">
        <img src="/photo/banner.jpg" class="w-full h-full object-cover object-center parallax-bg scale-[1.06]" />
      </div>
      <div class="hero-bg-overlay"></div>
      <div class="hero-buddha-glow"></div>
      
      <div class="relative z-10 w-full max-w-[820px] px-[80px] pb-[96px]">
        <p class="hero-el text-[#e8c97a] tracking-[0.22em] text-[12px] font-semibold mb-[24px] uppercase text-shadow-[0_0_20px_rgba(212,168,67,0.3)]" style="opacity:0; transform:translateY(20px);">聯合國教科文組織附屬機構 · 法國巴黎 · 成立於2017年</p>
        <h1 class="hero-el font-serif-tc text-[clamp(38px,5.5vw,72px)] leading-[1.35] mb-[28px] text-white drop-shadow-[0_2px_30px_rgba(0,0,0,0.3)]" style="opacity:0; filter:blur(20px);">
          透過<span class="text-transparent bg-clip-text bg-gradient-to-br from-[#e8c97a] to-[#d4a843]">智慧與文化</span><br/>傳遞永恆法音<br/>共築和平
        </h1>
        <p class="hero-el text-white/85 max-w-[540px] text-[16px] leading-[1.9] tracking-[0.05em] font-light mb-[40px]" style="opacity:0; filter:blur(20px);">聯合國教科文組織淨空之友社致力於在聯合國核心推廣宗教對話、傳統倫理與以智慧為本的教育。</p>
        
        <div class="hero-el flex flex-wrap gap-[16px] items-center" style="opacity:0; transform:translateY(20px);">
          <button class="px-[32px] py-[14px] bg-gradient-to-br from-[#d4a843] via-[#b8892a] to-[#7a5c1e] text-[#1a1208] text-[13px] font-semibold tracking-[0.12em] rounded-[2px] shadow-[0_4px_24px_rgba(180,130,30,0.4)] hover:-translate-y-[2px] hover:shadow-[0_8px_32px_rgba(180,130,30,0.5)] transition-all">探索活動</button>
          <button class="px-[32px] py-[13px] border border-white/35 text-white/90 text-[13px] font-medium tracking-[0.12em] rounded-[2px] hover:border-[#d4a843] hover:text-[#e8c97a] hover:bg-[rgba(212,168,67,0.08)] transition-all">教科文足跡 →</button>
        </div>
      </div>
    </section>

    <div class="py-[16px] bg-gradient-to-r from-[#7a5c1e] via-[#b8892a] to-[#7a5c1e] overflow-hidden flex text-[#1a1208] relative">
      <div class="flex animate-marquee whitespace-nowrap items-center">
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">聯合國教科文組織總部 · 巴黎</span><span class="text-black/50 px-[4px]">✦</span>
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">2026世界和平大會</span><span class="text-black/50 px-[4px]">✦</span>
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">倫理 · 道德 · 智慧 · 教育</span><span class="text-black/50 px-[4px]">✦</span>
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">教科文組織第40C/DR.1號決議</span><span class="text-black/50 px-[4px]">✦</span>
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">多元宗教和諧</span><span class="text-black/50 px-[4px]">✦</span>
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">上淨下空老和尚</span><span class="text-black/50 px-[4px]">✦</span>
      </div>
      <div class="flex animate-marquee whitespace-nowrap items-center" aria-hidden="true">
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">聯合國教科文組織總部 · 巴黎</span><span class="text-black/50 px-[4px]">✦</span>
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">2026世界和平大會</span><span class="text-black/50 px-[4px]">✦</span>
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">倫理 · 道德 · 智慧 · 教育</span><span class="text-black/50 px-[4px]">✦</span>
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">教科文組織第40C/DR.1號決議</span><span class="text-black/50 px-[4px]">✦</span>
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">多元宗教和諧</span><span class="text-black/50 px-[4px]">✦</span>
        <span class="px-[32px] font-serif-tc text-[16px] font-medium tracking-[0.15em]">上淨下空老和尚</span><span class="text-black/50 px-[4px]">✦</span>
      </div>
    </div>

    <section id="news" class="min-h-[600px] grid grid-cols-1 lg:grid-cols-2 bg-[#f9f3e1] relative">
      <div class="absolute inset-[20px] border border-[rgba(212,168,67,0.15)] pointer-events-none z-10"></div>
      <div class="relative overflow-hidden group">
        <img src="/photo/event.png" class="absolute inset-0 w-full h-full object-cover transition-transform duration-800 group-hover:scale-[1.04]" />
        <div class="absolute bottom-[32px] left-[32px] bg-gradient-to-br from-[#d4a843] to-[#b8892a] text-[#1a1208] text-[11px] font-semibold tracking-[0.16em] px-[16px] py-[8px] rounded-[2px] shadow-[0_4px_15px_rgba(180,130,30,0.3)] z-10">最新活動</div>
      </div>
      <div class="p-[72px] md:p-[64px] flex flex-col justify-center relative z-20">
        <div class="absolute top-[40px] right-[40px] w-[60px] h-[60px] border-t-2 border-r-2 border-[rgba(212,168,67,0.2)]"></div>
        <p class="text-[#7a5c1e] text-[13px] tracking-[0.14em] font-medium mb-[24px]">2026年3月8日–10日 · 教科文組織總部一號會議廳</p>
        <h2 class="font-serif-tc text-[clamp(28px,3.2vw,42px)] mb-[24px] text-[#1a1208] leading-[1.45] font-medium">百年淨空・地球母親・天下母親<br/>世界和平大會</h2>
        <p class="text-[#6b5533] leading-[2] text-[15px] font-light mb-[40px]">適逢上淨下空老和尚圓寂四週年暨百歲誕辰紀念之際，這場為期三天的歷史性盛會匯聚了來自世界各國的大使、學者與宗教領袖，共同探討女性在建設和平中的作用及構建和諧世界的基石。</p>
        <div class="border-t border-[#d4a843]/30 pt-8 space-y-4 text-sm text-[#9c7e4a] tracking-widest">
          <div class="flex justify-between items-center"><span class="text-xs">聯合主辦</span><span class="text-[#3d2e0f] font-medium text-right max-w-[60%]">馬達加斯加駐聯合國教科文組織代表團</span></div>
          <div class="flex justify-between items-center"><span class="text-xs">參與情況</span><span class="text-[#3d2e0f] font-medium text-right">來自30多個國家的代表</span></div>
        </div>
        <button class="mt-10 self-start px-[28px] py-[12px] border border-[#b8892a] text-[#7a5c1e] text-[12px] font-medium tracking-[0.12em] rounded-[2px] hover:bg-[#f5e8c0] transition-colors">查看完整報導 →</button>
      </div>
    </section>

    <section class="py-[120px] px-[80px] bg-[#fefcf5] relative">
      <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-[#d4a843]/30 to-transparent"></div>
      <div class="mb-[80px] text-center reveal-item">
          <p class="text-[#d4a843] text-[12px] tracking-[0.22em] uppercase mb-[16px] font-bold">01 — 活動訊息</p>
          <div class="w-[48px] h-[1px] bg-gradient-to-r from-[#d4a843] to-transparent mx-auto mb-[24px]"></div>
          <h2 class="font-serif-tc text-[clamp(34px,3.8vw,52px)] text-[#1a1208]">光輝<span class="text-transparent bg-clip-text bg-gradient-to-r from-[#7a5c1e] to-[#b8892a]">時刻</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-10 max-w-7xl mx-auto">
        <div class="md:col-span-1 space-y-[56px]">
          <div class="reveal-item group cursor-pointer">
            <div class="aspect-[4/3] overflow-hidden mb-[16px] shadow-sm"><img src="/photo/2017.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" /></div>
            <span class="text-[#b8892a] text-[11px] font-bold tracking-[0.16em] block mb-[12px]">2017年 · 教科文總部</span>
            <h3 class="text-[22px] font-serif-tc text-[#1a1208]">淨空之友社揭牌成立</h3>
          </div>
          <div class="reveal-item group cursor-pointer">
            <div class="aspect-square overflow-hidden mb-[16px] shadow-sm"><img src="/photo/2006.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" /></div>
            <span class="text-[#b8892a] text-[11px] font-bold tracking-[0.16em] block mb-[12px]">2006年 · 教科文總部</span>
            <h3 class="text-[22px] font-serif-tc text-[#1a1208]">與泰國代表團合辦衛塞節</h3>
          </div>
        </div>

        <div class="md:col-span-2 reveal-item group cursor-pointer">
          <div class="aspect-[16/10] overflow-hidden mb-[16px] shadow-md"><img src="/photo/2026.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" /></div>
          <span class="text-[#b8892a] text-[11px] font-bold tracking-[0.16em] block mb-[12px] mt-[8px]">2026年 · 聯合國教科文組織</span>
          <h3 class="text-[32px] font-serif-tc text-[#1a1208] mb-[12px]">百年淨空、地球母親世界和平大會暨三時繫念法會</h3>
          <p class="text-[#6b5533] text-[14px] leading-[1.8] font-light mt-[12px]">為回應當今世界對和平的渴望，來自全球的宗教領袖與學者齊聚巴黎，共同探討倫理教育與和諧共生的願景。</p>
        </div>

        <div class="md:col-span-1 space-y-[56px]">
          <div class="reveal-item group cursor-pointer">
            <div class="aspect-[3/4] overflow-hidden mb-[16px] shadow-sm"><img src="/photo/2019.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" /></div>
            <span class="text-[#b8892a] text-[11px] font-bold tracking-[0.16em] block mb-[12px]">2019年 · 教科文總部</span>
            <h3 class="text-[22px] font-serif-tc text-[#1a1208]">通過第40C/DR.1號決議</h3>
          </div>
          <div class="reveal-item group cursor-pointer">
            <div class="aspect-[4/3] overflow-hidden mb-[16px] shadow-sm"><img src="/photo/2023.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" /></div>
            <span class="text-[#b8892a] text-[11px] font-bold tracking-[0.16em] block mb-[12px]">2023年 · 教科文總部</span>
            <h3 class="text-[22px] font-serif-tc text-[#1a1208]">通過新的《和平教育建議書》</h3>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="py-[72px] px-[80px] bg-gradient-to-br from-[#7a5c1e] via-[#b8892a] to-[#d4a843] grid grid-cols-2 md:grid-cols-4 relative shadow-inner gap-[1px]">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_20%_50%,rgba(255,255,255,0.1)_0%,transparent_50%)] pointer-events-none"></div>
      
      <div class="text-center py-[40px] px-[32px] bg-gradient-to-br from-[#7a5c1e] to-[#b8892a] hover:from-[#b8892a] hover:to-[#d4a843] transition-colors relative reveal-item">
        <span class="text-[60px] font-serif-tc text-[#fefcf5] drop-shadow-[0_2px_10px_rgba(0,0,0,0.2)] stat-num block mb-[12px]" data-val="20">0</span>
        <p class="text-white/85 text-[12px] font-medium tracking-[0.16em] uppercase">參與教科文組織活動</p>
        <p class="text-white/65 text-[13px] font-light mt-[8px]">始於2003年</p>
      </div>
      <div class="text-center py-[40px] px-[32px] bg-gradient-to-br from-[#7a5c1e] to-[#b8892a] hover:from-[#b8892a] hover:to-[#d4a843] transition-colors relative reveal-item">
        <span class="text-[60px] font-serif-tc text-[#fefcf5] drop-shadow-[0_2px_10px_rgba(0,0,0,0.2)] stat-num block mb-[12px]" data-val="40">0</span>
        <p class="text-white/85 text-[12px] font-medium tracking-[0.16em] uppercase">參與國家</p>
        <p class="text-white/65 text-[13px] font-light mt-[8px]">遍佈五大洲</p>
      </div>
      <div class="text-center py-[40px] px-[32px] bg-gradient-to-br from-[#7a5c1e] to-[#b8892a] hover:from-[#b8892a] hover:to-[#d4a843] transition-colors relative reveal-item">
        <span class="text-[60px] font-serif-tc text-[#fefcf5] drop-shadow-[0_2px_10px_rgba(0,0,0,0.2)] stat-num block mb-[12px]" data-val="1300">0</span>
        <p class="text-white/85 text-[12px] font-medium tracking-[0.16em] uppercase">2018年參與人數</p>
        <p class="text-white/65 text-[13px] font-light mt-[8px]">歷史性首次法會</p>
      </div>
