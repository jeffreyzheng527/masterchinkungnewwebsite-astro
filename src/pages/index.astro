  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import Lenis from '@studio-freight/lenis';

    gsap.registerPlugin(ScrollTrigger);

    const lenis = new Lenis({ duration: 1.8, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), smooth: true });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0);

    const body = document.body;
    const ring = document.getElementById('cursor-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => {
      body.classList.add('show-cursor');
      mx = e.clientX; my = e.clientY;
    });
    function animateRing() {
      rx += (mx - rx) * 0.15; ry += (my - ry) * 0.15;
      if (ring) { ring.style.left = rx + 'px'; ring.style.top = ry + 'px'; }
      requestAnimationFrame(animateRing);
    }
    animateRing();

    const canvas = document.getElementById('dust-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d');
    let particles: any[] = [];
    function resizeCanvas() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
    resizeCanvas(); window.addEventListener('resize', resizeCanvas);

    class Particle {
      x: number = 0; y: number = 0; size: number = 0; speedY: number = 0; opacity: number = 0;
      constructor() { this.reset(); }
      reset() {
        this.x = Math.random() * canvas.width; this.y = Math.random() * canvas.height;
        this.size = Math.random() * 1.5 + 0.5; this.speedY = -Math.random() * 0.3 - 0.1;
        this.opacity = Math.random() * 0.5 + 0.1;
      }
      update() { this.y += this.speedY; if (this.y < 0) this.y = canvas.height; }
      draw() {
        if (!ctx) return;
        ctx.save(); ctx.globalAlpha = this.opacity; ctx.fillStyle = 'rgba(212, 168, 67, 0.8)'; 
        ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill(); ctx.restore();
      }
    }
    for (let i = 0; i < 50; i++) particles.push(new Particle());
    function animateParticles() {
      if(!ctx) return; ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach(p => { p.update(); p.draw(); }); requestAnimationFrame(animateParticles);
    }

    const veil = document.getElementById('entrance-veil');
    setTimeout(() => {
        if(veil) {
            gsap.to(veil, { opacity: 0, duration: 2, ease: 'power2.inOut', onComplete: () => veil.style.display = 'none' });
        }
        gsap.to('.hero-el', { opacity: 1, filter: 'blur(0px)', y: 0, stagger: 0.2, duration: 1.5, ease: 'power3.out', delay: 0.5 });
        canvas.classList.remove('opacity-0');
        animateParticles();
    }, 1200);

    gsap.utils.toArray(".reveal-item").forEach((item: any) => {
      gsap.from(item, { scrollTrigger: { trigger: item, start: "top 85%" }, opacity: 0, y: 40, duration: 1.2, ease: "power2.out" });
    });
    gsap.utils.toArray(".reveal-text").forEach((item: any) => {
      gsap.from(item, { scrollTrigger: { trigger: item, start: "top 80%" }, opacity: 0, x: 30, duration: 1.5, ease: "power2.out" });
    });

    const stats = document.querySelectorAll('.stat-num');
    stats.forEach((el: any) => {
      const val = parseInt(el.getAttribute('data-val'));
      ScrollTrigger.create({
        trigger: el, start: "top 90%",
        onEnter: () => {
          let count = { n: 0 };
          gsap.to(count, { n: val, duration: 2.5, ease: "power3.out", onUpdate: () => el.innerText = Math.floor(count.n).toString() });
        }
      });
    });

    const hContainer = document.getElementById("hTimeline");
    const getScrollAmount = () => -(hContainer ? hContainer.scrollWidth - window.innerWidth : 0);
    
    gsap.to(hContainer, {
      x: getScrollAmount,
      ease: "none",
      scrollTrigger: {
        trigger: "#footprints",
        pin: true,
        scrub: true, 
        end: () => `+=${getScrollAmount() * -1}`, 
        invalidateOnRefresh: true
      }
    });

    const nav = document.getElementById('main-nav');
    window.addEventListener('scroll', () => {
      if(window.scrollY > 60) {
          nav?.classList.add('nav-scrolled');
      } else {
          nav?.classList.remove('nav-scrolled');
      }
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const progressBar = document.getElementById('scroll-progress');
      if (progressBar) progressBar.style.width = (window.scrollY / total * 100) + '%';
    });
  </script>
